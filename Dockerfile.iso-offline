# ttyai ISO Builder — Offline Edition (OpenCode + Ollama)
# Supports both ARM64 and x86_64 via docker buildx --platform
FROM alpine:3.21 AS builder
ARG TARGETARCH

RUN apk add --no-cache \
    linux-lts \
    grub \
    grub-efi \
    xorriso \
    mtools \
    dosfstools \
    nodejs \
    npm \
    coreutils \
    curl \
    git \
    openssh-client \
    cpio \
    ca-certificates \
    zstd \
    && if [ "$TARGETARCH" = "amd64" ]; then apk add --no-cache grub-bios || true; fi \
    && rm -rf /var/cache/apk/*

# Pre-install OpenCode + Ollama + model
RUN npm install -g opencode-ai
RUN curl -fsSL https://ollama.com/install.sh | sh
RUN ollama serve & \
    sleep 5 && \
    ollama pull qwen2.5-coder:1.5b && \
    kill %1 2>/dev/null || true

RUN mkdir -p /iso/boot/grub /iso/boot/efi

WORKDIR /build

COPY iso/ttyai-init-offline.sh /build/ttyai-init-offline.sh
COPY iso/ttyai-interactive-offline.sh /build/ttyai-interactive-offline.sh
COPY iso/build-rootfs.sh /build/build-rootfs.sh
RUN chmod +x /build/ttyai-init-offline.sh /build/ttyai-interactive-offline.sh /build/build-rootfs.sh
COPY iso/grub-offline.cfg /iso/boot/grub/grub.cfg

RUN mkdir -p /rootfs && /build/build-rootfs.sh offline

RUN cp /boot/vmlinuz-lts /iso/boot/vmlinuz

RUN grub-mkrescue -o /build/ttyai.iso /iso/ 2>&1

FROM scratch AS output
COPY --from=builder /build/ttyai.iso /ttyai.iso
